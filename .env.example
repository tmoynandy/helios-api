# ─── Runtime ──────────────────────────────────────────────────────────────────
# APP_NAME — human-readable name shown in logs and health-check responses.
APP_NAME=helios-api
# LOG_LEVEL — verbosity: debug | info | warn | error
LOG_LEVEL=info
# PORT — TCP port the HTTP server binds to. Must match the Dockerfile EXPOSE and
#         the Kubernetes/Railway port mapping.
PORT=8080

# ─── Database (postgres) ───────────────────────────────────────────────────
# DATABASE_URL — Required. PostgreSQL connection string.
# Format: postgres://user:password@host:5432/dbname?sslmode=require
# Get it from: your local Postgres or any managed provider (Neon, Supabase, Railway)
DATABASE_URL=postgres://user:pass@localhost:5432/helios-api

# ─── Cache (redis) ─────────────────────────────────────────────────────────
# REDIS_URL — Required. Redis connection string.
# Format: redis://:password@host:6379 (or rediss:// for TLS)
# Get it from: your local Redis (brew install redis) or Upstash/Railway
REDIS_URL=redis://localhost:6379

# ─── Queue (RabbitMQ) ──────────────────────────────────────────────────────────
# RABBITMQ_URL — Required. AMQP connection string.
# Format: amqp://user:password@host:5672/vhost
# Get it from: cloudamqp.com or run locally via docker compose up rabbit
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Auth (Clerk) ─────────────────────────────────────────────────────
# Clerk issues RS256 JWTs. Find your instance's issuer and JWKS URL at dashboard.clerk.com → API Keys. `AUTH_AUDIENCE` is your Clerk application id (not required by Clerk but still validated when set).
# AUTH_ISSUER — Required. JWT issuer claim expected in every incoming token.
AUTH_ISSUER=https://your-instance.clerk.accounts.dev
# AUTH_JWKS_URL — Required. JWKS endpoint to fetch the signing public key.
AUTH_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# AUTH_AUDIENCE — Optional. When set, tokens with a mismatched aud claim are rejected.
AUTH_AUDIENCE=

# ─── Application ───────────────────────────────────────────────────────────────
DATABASE_URL=change-me
REDIS_URL=change-me
JWT_SECRET=change-me
LOG_LEVEL=change-me

